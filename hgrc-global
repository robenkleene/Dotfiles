# Put this in ~/.hgrc
# [ui]
# %include ~/.hgrc-global
[ui]
ignore = ~/.hgignore
# `internal:merge3` creates more complex merge conflict markers
# Without `internal:merge` or `internal:merge3` `hg` will automatically open
# conflicts in Vim
merge = internal:merge
[pager]
pager = less
[alias]
diff-rel = diff --root .
head = id -i
show-rel = diff --root . -c .
# Avoid aliases for common commands, depending on them makes working in contexts that don't have them more difficult (e.g., one of remote machines)
# cm = commit
# sh = show
# dr = diff --root .
# hd = id -i
# sr = diff --root . -c .
[committemplate]
%unset emptymsg
[extensions]
extdiff =
[extdiff]
cmd.vimdiff =
