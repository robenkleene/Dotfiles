# Put this in ~/.hgrc
# [ui]
# %include ~/.hgrc-global
[ui]
ignore = ~/.hgignore
# Try disabling this because it creates more complex merge conflict markets
# merge = internal:merge3
[pager]
pager = less
[alias]
dr = diff --root .
sr = diff --root . -c .
sh = show
cf = status --no-status --added --modified --change
cm = commit
[committemplate]
%unset emptymsg
[extensions]
extdiff =
[extdiff]
cmd.vimdiff =
