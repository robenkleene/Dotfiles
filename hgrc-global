# Put this in ~/.hgrc
# [ui]
# %include ~/.hgrc-global
[ui]
ignore = ~/.hgignore
# `internal:merge3` creates more complex merge conflict markers
# Without `internal:merge` or `internal:merge3` `hg` will automatically open
# conflicts in Vim
merge = internal:merge
[pager]
pager = less
[alias]
dr = diff --root .
sr = diff --root . -c .
sh = show
cf = status --no-status --added --modified --change
cm = commit
[committemplate]
%unset emptymsg
[extensions]
extdiff =
[extdiff]
cmd.vimdiff =
