{
  "for": {
    "body": "for (int ${1:i} = 0; $1 < ${2:10}; $1++) {\n    $0\n}",
    "description": "for",
    "prefix": "rk-for"
  },
  "print": {
    "body": "printf(\"$1\\n\");",
    "description": "print",
    "prefix": [
      "rk-p",
      "rk-printf"
    ]
  },
  "print var": {
    "body": "printf(\"$1 = %${2:i}\\n\", ${1});",
    "description": "print variable",
    "prefix": [
      "rk-pv",
      "rk-printf-var"
    ]
  },
  "template": {
    "body": "#include <stdio.h>\n\nint main() {\n    printf(\"hello, world\\n\");\n}",
    "description": "template",
    "prefix": "rk-template"
  },
  "while char": {
    "body": "while ((c = getchar()) != EOF) {\n    $0\n}",
    "description": "while char",
    "prefix": "rk-while-getchar"
  }
}
