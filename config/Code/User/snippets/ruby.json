{
  "each": {
    "body": "(${1:0}..${2:10}).each do |i|\n  ${0:puts i}\nend",
    "description": "each",
    "prefix": "rk-each"
  },
  "for": {
    "body": "for i in ${1:0}..${2:10}\n  ${0:puts i}\nend",
    "description": "for",
    "prefix": "rk-for"
  },
  "for in": {
    "body": "${1:ARGV}.each do |${2:item}|\n  ${0:puts $2}\nend",
    "description": "for in",
    "prefix": "rk-forin"
  },
  "print": {
    "body": "puts \"$1\"",
    "description": "print",
    "prefix": [
      "rk-p",
      "rk-puts"
    ]
  },
  "print err": {
    "body": "STDERR.puts \"${1:Error}\"",
    "description": "print err",
    "prefix": [
      "rk-pe",
      "rk-puts-err"
    ]
  },
  "print var": {
    "body": "puts \"$1 = #{${1}}\"",
    "description": "print var",
    "prefix": [
      "rk-pv",
      "rk-puts-var"
    ]
  },
  "template": {
    "body": "#!/usr/bin/env ruby\n\n",
    "description": "template",
    "prefix": "rk-template"
  }
}
