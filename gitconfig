[color]
	ui = auto
[core]
	excludesfile = ~/.gitignore
[push]
	default = simple
# Automatically create remote branches
	autoSetupRemote = true
# Try disabling this because it creates more complex merge conflict markets
# [merge]
# 	conflictstyle = diff3
[include]
	path = .gitconfig_local
[pull]
	ff = only
[user]
	name = Roben Kleene
	email = contact@robenkleene.com
[init]
	defaultBranch = main
[mergetool]
	prompt = false
[alias]
	diff-rel = diff --relative
	hash = rev-parse HEAD
	root = rev-parse --show-toplevel
	show-rel = show --relative
# Avoid aliases for common commands, depending on them makes working in contexts that don't have them more difficult (e.g., one of remote machines)
