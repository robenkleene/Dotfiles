[color]
	ui = auto
[core]
	excludesfile = ~/.gitignore
[push]
	default = simple
# Automatically create remote branches
	autoSetupRemote = true
# Try disabling this because it creates more complex merge conflict markets
# [merge]
# 	conflictstyle = diff3
[include]
	path = .gitconfig_local
[pull]
	ff = only
[user]
	name = Roben Kleene
	email = contact@robenkleene.com
[init]
	defaultBranch = main
[mergetool]
	prompt = false
[alias]
	br = branch
	cm = commit
	co = checkout
	di = diff
	dr = diff --relative
	hd = rev-parse HEAD
	head = rev-parse HEAD
	root = rev-parse --show-toplevel
	rt = rev-parse --show-toplevel
	sh = show
	sr = show --relative
	st = status
